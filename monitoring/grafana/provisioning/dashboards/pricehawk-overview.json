{
  "title": "PriceHawk - Complete Monitoring",
  "uid": "pricehawk-monitoring-v3",
  "description": "Frontend, Backend, System - cross-platform (Linux + Windows)",
  "tags": ["pricehawk", "monitoring"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 3,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "graphTooltip": 1,
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Datasource",
        "current": { "selected": false, "text": "Prometheus", "value": "prometheus" },
        "hide": 0
      }
    ]
  },
  "panels": [

    {
      "id": 1,
      "type": "row",
      "title": "System Health (Linux & Windows)",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },

    {
      "id": 2,
      "title": "CPU Usage % (alert: > 80%)",
      "description": "Linux: node_cpu_seconds_total | Windows: windows_cpu_time_total",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "100 - (avg by(instance)(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU Linux ({{ instance }})",
          "refId": "A"
        },
        {
          "expr": "100 - (avg by(instance)(rate(windows_cpu_time_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU Windows ({{ instance }})",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 80 }
            ]
          },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 3,
      "title": "Memory Usage % (alert: > 85%)",
      "description": "Linux: node_memory_* | Windows: windows_memory_*",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "Memory Linux ({{ instance }})",
          "refId": "A"
        },
        {
          "expr": "(1 - (windows_memory_available_bytes / windows_os_visible_memory_bytes)) * 100",
          "legendFormat": "Memory Windows ({{ instance }})",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 4,
      "title": "Disk Usage % (alert: > 85%)",
      "description": "Linux: node_filesystem_* | Windows: windows_logical_disk_* (C:, D:, ...)",
      "type": "gauge",
      "gridPos": { "x": 16, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "(1 - (node_filesystem_avail_bytes{fstype!~\"tmpfs|fuse.lxcfs|squashfs|overlay|devtmpfs\"} / node_filesystem_size_bytes{fstype!~\"tmpfs|fuse.lxcfs|squashfs|overlay|devtmpfs\"})) * 100",
          "legendFormat": "Linux {{ mountpoint }}",
          "refId": "A"
        },
        {
          "expr": "(1 - (windows_logical_disk_free_bytes{volume=~\"[A-Z]:\"} / windows_logical_disk_size_bytes{volume=~\"[A-Z]:\"})) * 100",
          "legendFormat": "Windows {{ volume }}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },

    {
      "id": 10,
      "type": "row",
      "title": "Backend API",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 1 }
    },

    {
      "id": 11,
      "title": "Backend Status",
      "type": "stat",
      "gridPos": { "x": 0, "y": 10, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "up{job=\"backend-api\"}",
          "legendFormat": "Backend",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": {
              "0": { "text": "DOWN", "color": "red" },
              "1": { "text": "UP", "color": "green" }
            }}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      }
    },

    {
      "id": 12,
      "title": "Request Rate (requests/s)",
      "type": "timeseries",
      "gridPos": { "x": 4, "y": 10, "w": 10, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by(status)(rate(http_server_requests_seconds_count{job=\"backend-api\"}[1m]))",
          "legendFormat": "HTTP {{ status }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 13,
      "title": "Response Time p95 (alert: > 1s)",
      "type": "timeseries",
      "gridPos": { "x": 14, "y": 10, "w": 10, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{job=\"backend-api\"}[5m]))",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, rate(http_server_requests_seconds_bucket{job=\"backend-api\"}[5m]))",
          "legendFormat": "p50 (median)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1 }
            ]
          },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 14,
      "title": "HTTP 5xx Errors per minute (alert: > 2)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 18, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "increase(http_server_requests_seconds_count{job=\"backend-api\",status=~\"5..\"}[1m])",
          "legendFormat": "5xx / min",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 2 }]
          },
          "custom": { "lineWidth": 2, "fillOpacity": 20 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 15,
      "title": "HTTP 4xx Rate % (alert: > 10%)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 18, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "(rate(http_server_requests_seconds_count{job=\"backend-api\",status=~\"4..\"}[5m]) / rate(http_server_requests_seconds_count{job=\"backend-api\"}[5m])) * 100",
          "legendFormat": "4xx rate %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 16,
      "title": "Active DB Connections (HikariCP)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 18, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "hikaricp_connections_active{job=\"backend-api\"}",
          "legendFormat": "Active",
          "refId": "A"
        },
        {
          "expr": "hikaricp_connections_max{job=\"backend-api\"}",
          "legendFormat": "Max (pool size)",
          "refId": "B"
        },
        {
          "expr": "hikaricp_connections_pending{job=\"backend-api\"}",
          "legendFormat": "Pending",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 20,
      "type": "row",
      "title": "Frontend (requires frontend SDK - see MONITORING.md)",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 25, "w": 24, "h": 1 }
    },

    {
      "id": 31,
      "title": "Page Load Time p95 (alert: > 3s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 26, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(frontend_page_load_seconds_bucket[5m]))",
          "legendFormat": "p95 page load",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1.5 },
              { "color": "red", "value": 3 }
            ]
          },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "noValue": "No data — cần tích hợp frontend SDK"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 32,
      "title": "Frontend API Error Rate % (alert: > 5%)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 26, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "(rate(frontend_api_errors_total[5m]) / rate(frontend_api_requests_total[5m])) * 100",
          "legendFormat": "API error rate %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "noValue": "No data — cần tích hợp frontend SDK"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 33,
      "title": "Frontend JS Error Rate /min (alert: > 10)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 26, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "rate(frontend_js_errors_total[1m]) * 60",
          "legendFormat": "JS errors/min",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "noValue": "No data — cần tích hợp frontend SDK"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    }

  ]
}
