# Copy file này thành .env rồi điền giá trị thực
# NEVER commit .env vào git (đã có trong .gitignore)
# cp .env.example .env  (Linux/Mac)
# copy .env.example .env  (Windows)

# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin123

# ── Prometheus ───────────────────────────────────────────────────────────────
PROMETHEUS_RETENTION_DAYS=15
PROMETHEUS_RETENTION_SIZE=10GB

# ── Email (dùng cho Grafana SMTP, tùy chọn) ──────────────────────────────────
# Cấu hình email chính thực hiện trong alertmanager/alertmanager.yml
# Phần dưới chỉ dùng nếu bạn muốn Grafana cũng tự gửi email
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com:587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM=alerts@pricehawl.com

# ── Log Collection ───────────────────────────────────────────────────────────
# Đường dẫn đến thư mục log của Spring Boot backend
# Promtail sẽ đọc *.log files trong thư mục này
#
# Windows dev (mặc định - logs trong project):
#   Để trống → dùng ../backend/logs (tương đối từ thư mục monitoring/)
#   Spring Boot cần: logging.file.name=logs/app.log trong application.yml
#
# Ubuntu production (log riêng):
#   BACKEND_LOG_PATH=/var/log/pricehawk/backend
#   Spring Boot cần: logging.file.name=/var/log/pricehawk/backend/app.log
#
BACKEND_LOG_PATH=../backend/logs
