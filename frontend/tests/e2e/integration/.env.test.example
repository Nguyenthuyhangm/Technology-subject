# Environment variables for E2E Integration Tests (Phase 2)
# Copy this file to .env.test and fill in your values

# =============================================================================
# BACKEND & FRONTEND URLs
# =============================================================================
BASE_URL=http://localhost:5173
BACKEND_URL=http://localhost:8080

# =============================================================================
# TEST USER CREDENTIALS
# Create a test user in your backend/Supabase before running tests
# =============================================================================
# E2E_TEST_EMAIL: Email của tài khoản test đã được tạo trong backend
# E2E_TEST_PASSWORD: Password của tài khoản test
E2E_TEST_EMAIL=testuser@pricehawk.vn
E2E_TEST_PASSWORD=TestPassword123!

# =============================================================================
# SUPABASE (for auth - required for real login)
# =============================================================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# =============================================================================
# NOTES
# =============================================================================
# 1. Chạy Docker Desktop + Redis trước
# 2. Chạy backend: cd backend && mvn spring-boot:run
# 3. Chạy frontend: cd frontend && npm run dev
# 4. Tạo user test trong Supabase Dashboard hoặc qua backend API
# 5. Chạy test: cd frontend && npx playwright test --config=tests/e2e/integration/playwright.config.ts
