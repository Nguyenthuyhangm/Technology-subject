# Backend URL dùng cho các màn hình gọi fetch trực tiếp. Để trống để dùng cùng origin.
# VITE_BACKEND_URL=
# VITE_BACKEND_URL=http://localhost:8080
#
# API base cho axios + trending deals. Để trống để dùng /api.
# VITE_API_BASE_URL=
# VITE_API_BASE_URL=/api
#
# Trending deals:
# VITE_USE_TRENDING_API=true
# VITE_USE_TRENDING_API=false

# Supabase
# VITE_SUPABASE_URL=
# VITE_SUPABASE_PUBLISHABLE_KEY=
# VITE_SUPABASE_ANON_KEY=
